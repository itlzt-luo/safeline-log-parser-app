{
  "name": "log-parser-app",
  "version": "1.0.0",
  "description": "日志解析和可视化应用",
  "main": "server/index.js",
  "scripts": {
    "server": "node server/index.js",
    "client": "cd client && npm start",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "build": "cd client && npm run build",
    "install-all": "npm install && cd client && npm install",
    "update-ip": "./scripts/update-ip-db.sh",
    "setup-cron": "./scripts/setup-cron.sh"
  },
  "keywords": [
    "log",
    "parser",
    "visualization"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "multer": "^1.4.5-lts.1"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
